# ── Server configuration ────────────────────────────────────────────────
# Port the Express proxy listens on. The Vite dev server proxies /api here.
PORT=3001

# ── API keys (all optional — the app works without them) ─────────────────
# Yahoo Finance is used for quotes, charts and options and needs NO key.
#
# Finnhub powers the News Feed and (optionally) higher-quality quotes.
# Get a free key (no credit card) at https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage is used as a fallback quote source.
# Get a free key (25 requests/day) at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ── AI features (DeepSeek) ────────────────────────────────────────────────
# Powers the AI news summaries (N → ✦ AI Summary) and the AI stock-analysis
# view (AI). WITHOUT this key the AI features show a "disabled" notice; every
# other feature works unchanged. Note: AI calls bill against your DeepSeek
# account (usage-based). Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# Optional: override the non-reasoning model (defaults to deepseek-chat).
DEEPSEEK_MODEL=
# Optional: override the reasoning model used for deeper analysis/chat calls
# (defaults to deepseek-reasoner).
DEEPSEEK_REASONER_MODEL=

# How long (seconds) the server caches upstream responses to protect free tiers.
CACHE_TTL_SECONDS=60
